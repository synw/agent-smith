{
  "name": "@agent-smith/nodetask",
  "version": "0.3.1",
  "description": "A toolkit to create human friendly agents: the nodejs tasks module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synw/agent-smith.git"
  },
  "scripts": {
    "build": "rm -rf dist/* && tsc",
    "watch": "tsc -w",
    "test": "jest --coverage",
    "docs": "typedoc --entryPointStrategy expand"
  },
  "dependencies": {
    "@agent-smith/agent": "file:../agent",
    "@agent-smith/task": "file:../task"
  },
  "devDependencies": {
    "@agent-smith/types": "file:../types",
    "@types/node": "^25.5.2",
    "openai": "6.33.0",
    "restmix": "^0.6.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "type": "module",
  "exports": {
